{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": [
      "localhost",
      "github.com",
      "*.github.com",
      "raw.githubusercontent.com",
      "release-assets.githubusercontent.com",
      "results-receiver.actions.githubusercontent.com",
      "*.blob.core.windows.net",
      "*.npmjs.org",
      "*.pypi.org",
      "html.duckduckgo.com",
      "mcp.context7.com",
      "proxy.golang.org",
      "nixos.org",
      "search.devbox.sh",
      "storage.googleapis.com",
      "sum.golang.org",
      "*.nixos.org",
      "mcp.atlassian.com",
      "cultureamp.atlassian.net"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "~",
      "~/.aws"
    ],
    "allowRead": [
      ".",
      "/nix",
      "/tmp",
      "/var",
      "~/.cache",
      "~/.claude",
      "~/.claude.json",
      "~/.config",
      "~/.gem_cache",
      "~/.gitconfig",
      "~/.local",
      "~/.nix-profile",
      "~/.npm-global",
      "~/.npmrc",
      "~/.pi",
      "~/.yarnrc",
      "~/.yarnrc.yml",
      "~/Downloads/",
      "~/Library",
      "~/dev",
      "~/go",
      "~/hotel"
    ],
    "allowWrite": [
      ".",
      "../.git",
      "../../.git",
      "../../../.git",
      "/tmp",
      "/var",
      "~/.cache/gh",
      "~/.cache/nix",
      "~/.cache/prek",
      "~/.cache/uv",
      "~/.local/share/devbox",
      "~/.local/share/hotel",
      "~/hotel",
      "~/.pi",
      "~/Library/Caches",
      "~/Library/pnpm",
      "~/go"
    ],
    "denyWrite": [
      "*.key",
      "*.pem",
      ".env",
      ".env.*",
      "./.pi/sandbox.json",
      "~/.pi/agent/sandbox.json"
    ]
  }
}
